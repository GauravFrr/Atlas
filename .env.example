# ═══════════════════════════════════════════════════════════════════════
# AGENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════
AGENT_NAME=Atlas
# Environment: development | staging | production
AGENT_ENV=development
# Log level: DEBUG | INFO | WARNING | ERROR
AGENT_LOG_LEVEL=INFO
# Dashboard access password (change this!)
DASHBOARD_PASSWORD=change_me_immediately
DASHBOARD_PORT=8000
# Supabase Postgres (recommended) — new project "agent-earns", pooler port 6543
# See docs/DATABASE.md
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
# Phase 2 dashboard auth (later):
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=
# Local dev: leave DATABASE_URL empty → ./agent.db

# ═══════════════════════════════════════════════════════════════════════
# LLM APIS
# Get Gemini key: https://aistudio.google.com
# Get Groq key:   https://console.groq.com
# ═══════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=
GROQ_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# GOOGLE APIs
# Setup: https://console.cloud.google.com
# Enable: Gmail API, Places API, Analytics API
# Create OAuth2 credentials, then run: python scripts/setup_gmail.py
# ═══════════════════════════════════════════════════════════════════════
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_ADDRESS=youragent@gmail.com
GOOGLE_PLACES_API_KEY=
GOOGLE_ANALYTICS_ID=
# Lead hunt: auto (Google if key set, else free OSM) | google | osm
LEAD_SCAN_SOURCE=auto
# M02: when OSM has few businesses and none look outdated, still pitch weakest sites
M02_SPARSE_FALLBACK=true

# ═══════════════════════════════════════════════════════════════════════
# SOCIAL MEDIA
# Reddit:  https://www.reddit.com/prefs/apps → create script app
# Twitter: https://developer.twitter.com → create app
# Buffer:  https://buffer.com → get access token
# Medium:  https://medium.com/me/settings → integration tokens
# ═══════════════════════════════════════════════════════════════════════
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USERNAME=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
BUFFER_ACCESS_TOKEN=
MEDIUM_INTEGRATION_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# PAYMENTS
# Razorpay: https://razorpay.com → Dashboard → API Keys
# Binance:  https://binance.com → Profile → API Management
# ═══════════════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_DEFAULT_AMOUNT_INR=3999
USD_TO_INR_RATE=85
PRICING_TIERS_FILE=data/pricing_tiers.json
RESUME_COOLDOWN_MINUTES=25
BINANCE_API_KEY=
BINANCE_SECRET=
# Your Binance Pay ID (find in Binance Pay → Receive)
BINANCE_PAY_ID=
# Your USDT TRC20 wallet address
USDT_TRC20_ADDRESS=

# ═══════════════════════════════════════════════════════════════════════
# DESIGN APIs
# Replicate: https://replicate.com → Account → API tokens
# Unsplash:  https://unsplash.com/developers → New Application
# Pexels:    https://www.pexels.com/api → Your API key
# ═══════════════════════════════════════════════════════════════════════
REPLICATE_API_TOKEN=
CANVA_API_KEY=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# FREELANCE PLATFORMS
# Fiverr: https://www.fiverr.com/settings/security → API Key
# Gumroad: https://app.gumroad.com/settings/advanced → Access token
# ═══════════════════════════════════════════════════════════════════════
FIVERR_API_KEY=
FIVERR_USERNAME=gauravstack
GUMROAD_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# COMMUNICATION
# Telegram: Message @BotFather → /newbot → get token
#           Then message your bot and visit:
#           https://api.telegram.org/bot<TOKEN>/getUpdates to get chat_id
# ═══════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional - for WhatsApp chatbot feature
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# DATA ENRICHMENT
# Hunter.io: https://hunter.io/api-keys (25 free searches/month)
# ExchangeRate: https://exchangerate-api.com (1500 free req/month)
# ═══════════════════════════════════════════════════════════════════════
HUNTER_API_KEY=
APOLLO_API_KEY=
YOUTUBE_API_KEY=
# Optional — only if approved for interactive apps (not bulk scraping). M16 works via free iTunes API without this.
LISTEN_NOTES_API_KEY=
PRODUCTHUNT_API_TOKEN=
EXCHANGERATE_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# SAFETY LIMITS (don't change unless you know what you're doing)
# ═══════════════════════════════════════════════════════════════════════
MAX_EMAILS_PER_DAY=400
MAX_LEADS_PER_DAY=200
MIN_LEAD_SCORE=6
EMAIL_COOLDOWN_DAYS=3
MAX_REVISIONS_PER_ORDER=2
QUALITY_SCORE_THRESHOLD=7.0

# ═══════════════════════════════════════════════════════════════════════
# YOUR INFO (used in invoices, emails, deliverables)
# ═══════════════════════════════════════════════════════════════════════
YOUR_NAME=Mikey
# Email copy uses Mikey strategy (icebreaker + 3-step sequence) — see docs/MIKEY_EMAIL_STRATEGY.md
YOUR_BUSINESS_NAME=
YOUR_EMAIL=
YOUR_UPI_ID=
YOUR_BANK_ACCOUNT=
YOUR_WISE_EMAIL=

# ═══════════════════════════════════════════════════════════════════════
# CAMPAIGN ORCHESTRATOR
# Public URL where demo HTML files are hosted (optional — included in emails)
# Business email SMTP (@gauravxd.dev) — see docs/BUSINESS_EMAIL_SETUP.md
# Not personal Gmail; use mailbox app password from Zoho / Workspace / etc.
# ═══════════════════════════════════════════════════════════════════════
# Your domain on R2 (see docs/GAURAVXD_R2_DOMAIN.md) — NOT the pub-xxxxx.r2.dev URL
DEMO_SITE_BASE_URL=https://demos.gauravxd.dev
# Cloudflare R2 — auto-upload demos after each campaign (S3 API)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=agent-demos
R2_ENDPOINT_URL=
R2_AUTO_UPLOAD=true
DEMO_UPLOAD_MODE=auto
# priority = Hostinger sites → Cloudflare R2; random = shuffle Hostinger per demo
DEMO_HOST_STRATEGY=priority
DEMO_SKIP_NETLIFY=true
DEMO_PREFER_R2=false

# Hostinger FTP — see docs/HOSTINGER_DEMO_SETUP.md
FTP_HOST=ftp.hostinger.com
FTP_PORT=21
FTP_USE_TLS=false
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_BASE=public_html/demos
HOSTINGER_SITES_FILE=data/hostinger_sites.json

SMTP_PROVIDER=zoho
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USER=hello@gauravxd.dev
SMTP_PASSWORD=
SMTP_FROM_EMAIL=hello@gauravxd.dev
SMTP_FROM_NAME=Gaurav
SMTP_REPLY_TO=
# Hostinger webmail Sent is empty for API/SMTP-only sends unless you enable:
SMTP_BCC_SELF=true
SMTP_SAVE_TO_SENT=true
SMTP_IMAP_HOST=

# How to send: draft | smtp | instantly | auto | hybrid
EMAIL_SEND_MODE=hybrid

# Instantly.ai — push leads to warmed campaign (see docs/INSTANTLY_SETUP.md)
# Use API v2 key (Growth+). New workspace: docs/INSTANTLY_HOSTINGER_SETUP.md
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
# Connect Hostinger mailboxes: python scripts/connect_instantly_mailboxes.py
INSTANTLY_REPLY_SYNC_LIMIT=50
REPLY_ALERT_ON_UNKNOWN=false
INSTANTLY_WEBHOOK_SECRET=
REPLY_SYNC_INTERVAL_MINUTES=15

# Daily runner (scripts/daily_campaign.py)
# DAILY_CAMPAIGN_CSV=d:\leads.csv
# DAILY_CAMPAIGN_NICHE=real_estate
# DAILY_CAMPAIGN_CITY=London
# DAILY_CAMPAIGN_LEADS=5

# Multiple Hostinger domains — copy data/outreach_domains.example.json → outreach_domains.json
OUTREACH_DOMAINS_FILE=data/outreach_domains.json
